# Godot 4+ specific ignores
/.godot/
/android/
# Godot headless/CI test runtime dirs (APPDATA/LOCALAPPDATA overrides)
/.godot_test_*/

# 配置表导出工具本地输出（previews / inspect / 副本 xlsx）
/outputs/
**/*.inspect.ndjson
/.codex_spreadsheet_work/
__pycache__/
/backpack_preview*.png
/backpack_preview*.wav
/backpack_preview*.png.import
/backpack_preview*.wav.import

# Editor/user-specific caches (never commit)
/.godot/editor/
!/.godot/editor/project_metadata.cfg
/.godot/imported/
/.godot/mono/
/.godot/uid_cache.bin
